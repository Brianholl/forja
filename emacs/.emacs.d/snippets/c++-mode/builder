  $2 &set_masa   (const std::string &v) { pizza_.masa    = v; return *this; }
  $2 &set_salsa  (const std::string &v) { pizza_.salsa   = v; return *this; }
  $2 &set_topping(const std::string &v) { pizza_.topping = v; return *this; }
