# ==========================================
# 🎮 UNREAL ENGINE COMMANDER FOR LINUX
# ==========================================

# Configuración Global
export UE_ROOT="$HOME/UnrealEngine" # [cite: 8]
export UE_EDITOR_BIN="$UE_ROOT/Engine/Binaries/Linux/UE4Editor"
export UE_UBT="$UE_ROOT/Engine/Build/BatchFiles/Linux/Build.sh"
export UE_GEN="$UE_ROOT/Engine/Build/BatchFiles/Linux/GenerateProjectFiles.sh"
export UE_UAT="$UE_ROOT/Engine/Build/BatchFiles/RunUAT.sh"
# --- OPTIMIZACIÓN DE COMPILACIÓN (CCACHE) ---
# Instalar sudo pacman -S ccache
export UE_USE_CCACHE=1
export CCACHE_DIR="$HOME/.ccache"
# Opcional: Dale bastante espacio (ej: 50GB) para que no borre cosas viejas
# Ejecuta una sola vez en terminal: ccache -M 50G
# Para ver cuanto esta usado:ccache -s


# Función auxiliar para encontrar el .uproject
function _ue_get_project() {
    local PROJ=$(find "$(pwd)" -maxdepth 1 -name "*.uproject" | head -n 1)
    if [ -z "$PROJ" ]; then
        echo "❌ Error: No veo ningún archivo .uproject en $(pwd)"
        return 1
    fi
    echo "$PROJ"
}

# ------------------------------------------
# 1. GESTIÓN DE PROYECTOS (Gen & Build)
# ------------------------------------------

# Equivalente a tu lógica de [cite: 50]
function ue-gen() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🔨 Generando Makefiles para: $(basename "$PROJ")"
    "$UE_GEN" -project="$PROJ" -game -engine
}

# Equivalente a tu lógica de [cite: 51]
function ue-build() {
    local PROJ=$(_ue_get_project) || return 1
    local PROJ_NAME=$(basename "$PROJ" .uproject)
    echo "🏗️  Compilando ${PROJ_NAME}Editor Linux Development..."
    make "${PROJ_NAME}Editor" Linux Development
}

# El combo reparador [cite: 54]
function ue-init() {
    ue-gen && ue-build
}

# ------------------------------------------
# 2. EJECUCIÓN (Reemplaza a my/ue-run )
# ------------------------------------------

function ue-open() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🚀 Abriendo Editor..."
    "$UE_EDITOR_BIN" "$PROJ" &
}

function ue-log() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🚀 Abriendo Editor con LOG (Ideal para debug)..."
    "$UE_EDITOR_BIN" "$PROJ" -log &
}

function ue-game() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🎮 Lanzando Juego Standalone..."
    "$UE_EDITOR_BIN" "$PROJ" -game -log -windowed -resX=1280 -resY=720
}

# ------------------------------------------
# 3. COCINADO Y EMPAQUETADO (Reemplaza scripts [cite: 30, 31])
# ------------------------------------------

function ue-cook() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🍳 Cocinando Assets..."
    "$UE_EDITOR_BIN" "$PROJ" -run=cook -targetplatform=LinuxNoEditor
}

function ue-package() {
    local PROJ=$(_ue_get_project) || return 1
    local DIST_DIR="$(pwd)/Dist"
    echo "📦 Empaquetando para Linux en: $DIST_DIR"
    "$UE_UAT" BuildCookRun \
        -project="$PROJ" \
        -noP4 -platform=Linux -clientconfig=Shipping -serverconfig=Shipping \
        -cook -allmaps -build -stage -pak -archive \
        -archivedirectory="$DIST_DIR"
}

# ------------------------------------------
# 4. EXTRAS (Reemplaza my/ue-generate-compile-commands )
# ------------------------------------------

function ue-clang() {
    local PROJ=$(_ue_get_project) || return 1
    echo "🧠 Generando compile_commands.json (Clangd)..."
    
    # Esta es la lógica compleja de CMake que tenías en Emacs [cite: 47]
    # Nota: Ajusta la ruta del toolchain si cambia tu versión de UE
    local TOOLCHAIN="$UE_ROOT/Engine/Extras/ThirdPartyNotUE/SDKs/HostLinux/Linux_x64/v22_clang-16.0.6-centos7"
    
    # 1. Generar CMake files
    "$UE_GEN" -project="$PROJ" -game -engine -cmakefile
    
    # 2. Exportar comandos
    export LINUX_MULTIARCH_ROOT="$TOOLCHAIN"
    cmake -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_POLICY_VERSION_MINIMUM=3.5 .
    
    echo "✅ compile_commands.json generado."
}
