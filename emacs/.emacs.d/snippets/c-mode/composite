#include <string.h>

/* -------------------------------------------------------
 * Patrón Composite en C
 * Intención: componer objetos en estructuras de árbol y
 * tratar a hoja y compuesto de forma uniforme.
 * En C: struct con función-punteros + lista de hijos.
 * ------------------------------------------------------- */

#define MAX_HIJOS 16

typedef struct ${1:Componente} $1;
struct $1 {
    char  nombre[32];
    void (*operacion)(const $1 *self, int profundidad);
    void (*agregar)  ($1 *self, $1 *hijo);   /* NULL en hojas */
    $1   *hijos[MAX_HIJOS];
    int   n_hijos;
};

/* --- Hoja --- */

static void hoja_operacion(const $1 *self, int prof) {
    for (int i = 0; i < prof; i++) printf("  ");
    printf("- %s\n", self->nombre);
}

$1 *nueva_hoja(const char *nombre) {
    $1 *h = calloc(1, sizeof *h);
    strncpy(h->nombre, nombre, sizeof h->nombre - 1);
    h->operacion = hoja_operacion;
    h->agregar   = NULL;
