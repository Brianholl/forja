#include <string.h>

/* -------------------------------------------------------
 * Patrón Prototype en C
 * Intención: clonar objetos sin depender de su tipo concreto.
 * En C: función clone() en la propia struct (función-puntero).
 * ------------------------------------------------------- */

typedef struct ${1:Forma} $1;

struct $1 {
    int   x, y;
    char  tipo[32];
    $1  *(*clone)(const $1 *self);
    void (*imprimir)(const $1 *self);
};

/* --- Círculo --- */

static $1 *circulo_clone(const $1 *self) {
    $1 *copia = malloc(sizeof *copia);
    *copia = *self;
    return copia;
}

static void circulo_imprimir(const $1 *self) {
    printf("Círculo en (%d, %d)\n", self->x, self->y);
}

$1 *crear_circulo(int x, int y) {
    $1 *c = malloc(sizeof *c);
    c->x = x; c->y = y;
    strcpy(c->tipo, "Circulo");
    c->clone    = circulo_clone;
    c->imprimir = circulo_imprimir;
    return c;
}

/* --- Rectángulo --- */

