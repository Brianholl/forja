<?php
// Observer — SplSubject / SplObserver de la SPL
class ${1:Pedido} implements \SplSubject
{
    private string $estado = 'pendiente';
    private \SplObjectStorage $observadores;

    public function __construct(public readonly int $id)
    {
        $this->observadores = new \SplObjectStorage();
    }

    public function attach(\SplObserver $o): void { $this->observadores->attach($o); }
    public function detach(\SplObserver $o): void { $this->observadores->detach($o); }

    public function notify(): void
    {
        foreach ($this->observadores as $o) { $o->update($this); }
    }

    public function cambiarEstado(string $estado): void
    {
        $this->estado = $estado;
        echo "[Pedido #{$this->id}] → {$estado}\n";
        $this->notify();
    }

    public function getEstado(): string { return $this->estado; }
}

