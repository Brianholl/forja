}

/* --- Compuesto --- */

static void compuesto_operacion(const $1 *self, int prof) {
    for (int i = 0; i < prof; i++) printf("  ");
    printf("+ %s\n", self->nombre);
    for (int i = 0; i < self->n_hijos; i++)
        self->hijos[i]->operacion(self->hijos[i], prof + 1);
}

static void compuesto_agregar($1 *self, $1 *hijo) {
    if (self->n_hijos < MAX_HIJOS)
        self->hijos[self->n_hijos++] = hijo;
}

$1 *nuevo_compuesto(const char *nombre) {
    $1 *c = calloc(1, sizeof *c);
    strncpy(c->nombre, nombre, sizeof c->nombre - 1);
    c->operacion = compuesto_operacion;
    c->agregar   = compuesto_agregar;
    return c;
}

